generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  PRINCIPAL
  TEACHER
  STUDENT
  PARENT
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum PaymentStatus {
  PAID
  DUE
  PARTIAL
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum AcademicYearStatus {
  ACTIVE
  ENDED
  UPCOMING
}

enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id       String  @id @default(cuid())
  email    String  @unique
  password String
  role     Role
  name     String?
  image    String?

  // Security & Status
  isActive     Boolean   @default(true)
  isFirstLogin Boolean   @default(true)
  lastLogin    DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  studentProfile StudentProfile?
  teacherProfile TeacherProfile?
  parentProfile  ParentProfile?

  // Shared messaging
  sentMessages     Message[] @relation("SentMessages")
  receivedMessages Message[] @relation("ReceivedMessages")

  // Audit
  actionsPerformed AuditLog[]
}

model ParentProfile {
  id   String @id // same as user.id
  user User   @relation(fields: [id], references: [id], onDelete: Cascade)

  phone      String
  address    String?
  occupation String?

  students StudentProfile[]

  @@map("parent_profiles")
}

model StudentProfile {
  id   String @id // same as user.id
  user User   @relation(fields: [id], references: [id], onDelete: Cascade)

  // Personal
  dob                DateTime
  gender             Gender
  address            String
  nationality        String
  religion           String?
  identificationMark String?

  // Parents (Legacy strings kept for record, but linking to ParentProfile is new)
  fatherName       String
  motherName       String
  guardianName     String?
  parentContact    String
  emergencyContact String?

  parents ParentProfile[]

  // Academic
  admissionNo   String  @unique
  admissionYear Int
  rollNo        String?

  // Current placement
  classroomId String?
  classroom   Classroom? @relation(fields: [classroomId], references: [id])
  sectionId   String?
  section     Section?   @relation(fields: [sectionId], references: [id])

  // Transport
  transportRoute String?
  pickupPoint    String?

  attendance    Attendance[]
  examResults   ExamResult[]
  payments      Payment[]
  leaveRequests LeaveRequest[]

  // Status
  isArchived Boolean   @default(false)
  archivedAt DateTime?

  @@map("student_profiles")
}

model TeacherProfile {
  id   String @id // same as user.id
  user User   @relation(fields: [id], references: [id], onDelete: Cascade)

  qualification String[]
  designation   String?
  joiningDate   DateTime

  // Responsibilities
  classTeacherOfId String?    @unique
  classTeacherOf   Classroom? @relation("ClassTeacher", fields: [classTeacherOfId], references: [id])

  subjectsTaught   Subject[]
  leaveRequests    LeaveRequest[]
  timetableEntries TimetableEntry[]

  // Salary & Finance
  salary   Float? // Base yearly/monthly salary
  payrolls Payroll[]

  // Class Management
  announcements Announcement[]
  onlineClasses OnlineClass[]

  @@map("teacher_profiles")
}

model AcademicYear {
  id        String             @id @default(cuid())
  name      String             @unique // e.g. "2023-24"
  startDate DateTime
  endDate   DateTime
  status    AcademicYearStatus @default(UPCOMING)

  exams       Exam[]
  attendances Attendance[]
  fees        FeeStructure[]
  promotions  PromotionHistory[]
  timetable   TimetableEntry[]

  @@map("academic_years")
}

model Classroom {
  id   String @id @default(cuid())
  name String // e.g. "Class 10"
  code String @unique // e.g. "CLASS_10" - Fixed for promotion logic

  sections Section[]
  subjects Subject[]

  students StudentProfile[]

  classTeacher TeacherProfile? @relation("ClassTeacher")

  // Promotion mapping
  nextClassroomCode String? // Pointer to next class (e.g. CLASS_11)

  timetableEntries TimetableEntry[]
  onlineClasses    OnlineClass[]
  announcements    Announcement[]

  @@map("classrooms")
}

model Section {
  id          String    @id @default(cuid())
  name        String // "A", "B"
  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  students StudentProfile[]

  @@unique([classroomId, name])
  @@map("sections")
}

model Subject {
  id   String  @id @default(cuid())
  name String
  code String?

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   TeacherProfile? @relation(fields: [teacherId], references: [id])

  exams            Exam[]
  timetableEntries TimetableEntry[]
  onlineClasses    OnlineClass[]

  @@map("subjects")
}

model TimetableEntry {
  id String @id @default(cuid())

  dayOfWeek DayOfWeek
  startTime String // HH:mm
  endTime   String // HH:mm

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id], onDelete: Cascade)

  teacherId String?
  teacher   TeacherProfile? @relation(fields: [teacherId], references: [id])

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  @@map("timetable_entries")
}

model Attendance {
  id     String           @id @default(cuid())
  date   DateTime
  status AttendanceStatus

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  recordedById String? // Teacher ID

  @@unique([studentId, date])
  @@map("attendance_records")
}

model LeaveRequest {
  id        String      @id @default(cuid())
  reason    String
  startDate DateTime
  endDate   DateTime
  status    LeaveStatus @default(PENDING)

  studentId String?
  student   StudentProfile? @relation(fields: [studentId], references: [id])

  teacherId String?
  teacher   TeacherProfile? @relation(fields: [teacherId], references: [id])

  approvedById String? // User who approved
  createdAt    DateTime @default(now())

  @@map("leave_requests")
}

model Exam {
  id   String @id @default(cuid())
  name String // "Mid-Term", "Final"

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id], onDelete: Cascade)

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  totalMarks   Float
  passingMarks Float

  date DateTime?

  results ExamResult[]

  isPublished Boolean @default(false)
  isLocked    Boolean @default(false) // Teachers can't edit after lock

  @@map("exams")
}

model ExamResult {
  id     String @id @default(cuid())
  examId String
  exam   Exam   @relation(fields: [examId], references: [id], onDelete: Cascade)

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id], onDelete: Cascade)

  marksObtained Float
  remarks       String?

  @@unique([examId, studentId])
  @@map("exam_results")
}

model FeeStructure {
  id        String @id @default(cuid())
  name      String // "Tuition Fee", "Lab Fee"
  amount    Float
  frequency String // "MONTHLY", "YEARLY", "ONCE"

  academicYearId String
  academicYear   AcademicYear @relation(fields: [academicYearId], references: [id])

  // Could link to specific classes if fees differ
  // For simplicity, assumed global or managed via logic.
  // Adding optional specific class link:
  forClassroomId String?

  payments Payment[]

  @@map("fee_structures")
}

model Payment {
  id String @id @default(cuid())

  studentId String
  student   StudentProfile @relation(fields: [studentId], references: [id])

  feeId String
  fee   FeeStructure @relation(fields: [feeId], references: [id])

  amountPaid Float
  date       DateTime      @default(now())
  status     PaymentStatus
  receiptNo  String        @unique

  month String? // e.g. "January" if monthly
  year  Int? // e.g. 2024

  @@map("payments")
}

model PromotionHistory {
  id   String   @id @default(cuid())
  date DateTime @default(now())

  fromAcademicYearId String
  toAcademicYearId   String? // Null if graduated/archived

  academicYear AcademicYear @relation(fields: [fromAcademicYearId], references: [id])

  details Json // Store logs of how many promoted, errors, etc.

  @@map("promotion_history")
}

model Message {
  id        String   @id @default(cuid())
  content   String
  subject   String?
  createdAt DateTime @default(now())
  isRead    Boolean  @default(false)

  senderId String
  sender   User   @relation("SentMessages", fields: [senderId], references: [id])

  receiverId String
  receiver   User   @relation("ReceivedMessages", fields: [receiverId], references: [id])

  attachments String[] // URLs

  @@map("messages")
}

model Notification {
  id        String   @id @default(cuid())
  title     String
  message   String
  roles     Role[] // Who sees this?
  createdAt DateTime @default(now())

  // Or specific user
  userId String?

  @@map("notifications")
}

model OnlineClass {
  id       String   @id @default(cuid())
  title    String
  date     DateTime
  meetLink String // Zoom/Google Meet link

  subjectId String
  subject   Subject @relation(fields: [subjectId], references: [id])

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id])

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  createdAt DateTime @default(now())

  @@map("online_classes")
}

model Announcement {
  id        String   @id @default(cuid())
  title     String
  content   String
  createdAt DateTime @default(now())

  classroomId String
  classroom   Classroom @relation(fields: [classroomId], references: [id])

  authorId String
  author   TeacherProfile @relation(fields: [authorId], references: [id])

  attachments String[] // URLs

  @@map("announcements")
}

model Payroll {
  id     String        @id @default(cuid())
  month  String
  year   Int
  amount Float
  status PaymentStatus @default(PAID)
  paidAt DateTime      @default(now())

  teacherId String
  teacher   TeacherProfile @relation(fields: [teacherId], references: [id])

  @@map("payrolls")
}

model AuditLog {
  id       String  @id @default(cuid())
  action   String
  entity   String // e.g. "Student"
  entityId String?
  details  Json?

  actorId String
  actor   User   @relation(fields: [actorId], references: [id])

  createdAt DateTime @default(now())

  @@map("audit_logs")
}
